{
  "name": "pi-workflow-engine",
  "version": "0.11.0",
  "type": "module",
  "description": "Zero-dependency Dynamax workflows for pi: live parallel subagents, typed handoffs, synthesized results.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-workflow",
    "workflow-engine",
    "multi-agent",
    "coding-agent"
  ],
  "license": "MIT",
  "homepage": "https://github.com/timbrinded/pi-workflow-engine#readme",
  "bugs": {
    "url": "https://github.com/timbrinded/pi-workflow-engine/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timbrinded/pi-workflow-engine.git"
  },
  "files": [
    ".pi/extensions/pi-workflow-engine",
    ".pi/settings.json",
    "assets/preview.png",
    "skills",
    "README.md",
    "USAGE.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [".pi/extensions/pi-workflow-engine/index.ts"],
    "skills": ["skills"],
    "image": "https://raw.githubusercontent.com/timbrinded/pi-workflow-engine/master/assets/preview.png"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test --timeout=30000",
    "test:changedlines": "bun test tests/changedlines.test.ts",
    "test:concurrency": "bun test tests/concurrency.test.ts",
    "test:smoke": "bun test tests/discovery.test.ts",
    "test:ui": "bun test tests/workflow-ui.test.ts",
    "bench": "bun run bench:concurrency && bun run bench:discovery && bun run bench:ui",
    "bench:concurrency": "bun run scripts/bench/concurrency.ts",
    "bench:discovery": "bun run scripts/bench/discovery.ts",
    "bench:startup": "bun run scripts/bench/startup.ts",
    "bench:ui": "bun run scripts/bench/ui.ts",
    "prepublishOnly": "tsc --noEmit && bun run test"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^7.0.2"
  }
}
